{
  "name": "aegisops-local-ai",
  "version": "2.0.0",
  "description": "AegisOps Local AI v2.0 — Enterprise AI Platform with PostgreSQL/TimescaleDB, Kafka Event Bus, SCADA DMZ, Real ETL Pipelines, Parallel DAG Workflows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server/standalone.js",
    "server:lan": "cross-env BIND=0.0.0.0 node server/standalone.js",
    "server:gateway": "cross-env BIND=0.0.0.0 GATEWAY=1 node server/standalone.js",
    "server:public": "cross-env BIND=0.0.0.0 AEGISOPS_TUNNEL=cloudflared node server/standalone.js",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint server public/js --ext .js",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "postinstall": "electron-builder install-app-deps || true"
  },
  "author": "AegisOps Team <support@aegisops.com>",
  "homepage": "https://github.com/FreedoomForm/goal",
  "repository": {
    "type": "git",
    "url": "https://github.com/FreedoomForm/goal.git"
  },
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "cross-env": "^7.0.3",
    "express": "^4.21.0",
    "kafkajs": "^2.2.4",
    "marked": "^15.0.0",
    "node-cron": "^3.0.3",
    "node-opcua-client": "^2.133.0",
    "nodemailer": "^6.9.0",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "sql.js": "^1.11.0",
    "uuid": "^10.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.12.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "build": {
    "appId": "com.aegisops.localai",
    "productName": "AegisOps Local AI",
    "forceCodeSigning": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!**/*.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "AegisOps-LocalAI-${version}-${arch}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development;Office;Utility",
      "icon": "assets/icon.png",
      "artifactName": "AegisOps-LocalAI-${version}-${arch}.${ext}",
      "desktop": {
        "Name": "AegisOps Local AI",
        "Comment": "Enterprise AI Integration Platform for gas balance forecasting",
        "Categories": "Development;Office;Utility",
        "Keywords": "AI;enterprise;SCADA;OPC;UA;gas;forecasting"
      }
    },
    "deb": {
      "depends": [
        "libglib2.0-0",
        "libsecret-1-0",
        "libx11-6"
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity"
    }
  }
}
