# ──────────────────────────────────────────────────────────────
# AegisOps — environment variable template
# Copy to `.env` and fill in the values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────

# HTTP server
BIND=127.0.0.1
PORT=18090
NODE_ENV=development

# Server secret (JWT signing + AES-256-GCM credential encryption)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AEGISOPS_SECRET=

# CORS — comma-separated list of allowed browser origins.
# Leave AEGISOPS_CORS_WILDCARD=1 only in development.
AEGISOPS_CORS_ORIGINS=
AEGISOPS_CORS_WILDCARD=0

# PostgreSQL / TimescaleDB (primary database)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=aegisops
PG_USER=aegisops
PG_PASSWORD=change_me
PG_SSL=false

# Kafka (optional; falls back to in-process EventEmitter)
KAFKA_BROKERS=
KAFKA_CLIENT_ID=aegisops
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# Tunnel (optional: cloudflared | ngrok | none)
AEGISOPS_TUNNEL=
GATEWAY=1
GATEWAY_PORT=18091
