<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Enforce HTTPS by default for production (tunnel URLs). -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext for local development and LAN pairing.
         Note: <domain> matches exact hostnames, not CIDR ranges.
         For LAN pairing, we allow cleartext to common private IP patterns
         and localhost. Users pairing with specific LAN IPs will work if
         the IP matches one of these entries or if they use HTTPS. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.0.2</domain>
        <domain includeSubdomains="true">local</domain>
        <domain includeSubdomains="true">lan</domain>
        <domain includeSubdomains="true">home</domain>
        <domain includeSubdomains="true">internal</domain>
    </domain-config>
</network-security-config>
